{
  "http_listen": ":8444",
  "auth": {
    "mode": "jwt",
    "jwt": {
      "audience": ["trading-gateway", "trading-push"],
      "issuers": [
        {
          "issuer": "https://auth.your-company.internal",
          "jwks_url": "https://auth.your-company.internal/.well-known/jwks.json"
        },
        {
          "issuer": "trading-matchengine-dev",
          "hs256_secret_file": "/etc/trading/auth-hs256.secret"
        }
      ]
    }
  },
  "tls": {
    "enabled": true,
    "cert_file": "/etc/trading/tls/push.crt",
    "key_file": "/etc/trading/tls/push.key",
    "client_ca_file": "/etc/trading/tls/ca.crt",
    "require_client_cert": true
  },
  "redis": {
    "addr": "redis.internal:6379",
    "password": "",
    "db": 0
  },
  "log": {
    "level": "info",
    "dev": false,
    "file": "logs/push.log"
  }
}

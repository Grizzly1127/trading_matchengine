{
  "http_listen": ":8081",
  "auth": {
    "mode": "static",
    "static_token": "dev-token-change-me"
  },
  "tls": {
    "enabled": false
  },
  "limits": {
    "retail_max_connections": 5,
    "retail_max_symbols_per_connection": 50,
    "market_maker_max_connections": 3
  },
  "redis": {
    "addr": "localhost:6379",
    "password": "",
    "db": 0
  },
  "log": {
    "level": "info",
    "dev": true,
    "file": "logs/push.log",
    "async": true,
    "buffer_size": 512,
    "max_size_mb": 100,
    "max_age_days": 7,
    "max_backups": 30,
    "compress": true,
    "local_time": true,
    "rotate_daily": true
  }
}

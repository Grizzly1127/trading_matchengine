{
  "grpc_listen": ":50054",
  "database_url": "postgres://trading:trading@localhost:5432/trading?sslmode=disable",
  "symbols": ["BTC-USDT"],
  "poll_interval_ms": 1000,
  "fetch_timeout_ms": 800,
  "stale_after_ms": 60000,
  "redis_key_ttl_ms": 10000,
  "aggregator": {
    "deviation_threshold": "0.03",
    "min_sources": 1
  },
  "sources": {
    "mock": {
      "enabled": false,
      "weight": "1"
    },
    "binance": {
      "enabled": true,
      "weight": "1"
    },
    "okx": {
      "enabled": true,
      "weight": "1"
    },
    "bybit": {
      "enabled": true,
      "weight": "1"
    }
  },
  "mock": {
    "base_prices": {
      "BTC-USDT": "65000"
    },
    "default_base": "65000"
  },
  "kafka": {
    "brokers": ["localhost:9092"],
    "index_topic": "index.price",
    "producer_enabled": true
  },
  "redis": {
    "addr": "localhost:6379",
    "password": "",
    "db": 0
  },
  "log": {
    "level": "debug",
    "dev": true,
    "file": "logs/indexprice.log",
    "async": true,
    "buffer_size": 512,
    "max_size_mb": 100,
    "max_age_days": 7,
    "max_backups": 30,
    "compress": true,
    "local_time": true,
    "rotate_daily": true
  }
}

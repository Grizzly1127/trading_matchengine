{
  "http_listen": ":8090",
  "issuer": "trading-matchengine-dev",
  "audience": ["trading-gateway", "trading-push"],
  "hs256_secret_file": "configs/auth-dev-hs256.secret",
  "token_ttl_seconds": 900,
  "clients": [
    {
      "client_id": "web-bff",
      "client_secret": "dev-client-secret-change-me",
      "scopes": [
        "orders:read",
        "orders:write",
        "balances:read",
        "balances:admin",
        "market:read",
        "push:connect"
      ]
    },
    {
      "client_id": "clearing",
      "client_secret": "dev-clearing-secret-change-me",
      "scopes": ["balances:read", "balances:admin"]
    },
    {
      "client_id": "market-maker",
      "client_secret": "dev-mm-secret-change-me",
      "scopes": ["market:read", "push:connect", "push:ticker_all"]
    }
  ],
  "log": {
    "level": "info",
    "dev": true
  }
}

{
  "http_listen": ":8080",
  "order_service": {
    "grpc_addr": "localhost:50051",
    "dial_seconds": 10
  },
  "marketdata_service": {
    "grpc_addr": "localhost:50052",
    "dial_seconds": 10
  },
  "kline_service": {
    "grpc_addr": "localhost:50053",
    "dial_seconds": 10
  },
  "symbols_file": "configs/symbols.json",
  "auth": {
    "mode": "static",
    "static_token": "dev-token-change-me"
  },
  "tls": {
    "enabled": false
  },
  "log": {
    "level": "info",
    "dev": true,
    "file": "logs/gateway.log",
    "async": true,
    "buffer_size": 512,
    "max_size_mb": 100,
    "max_age_days": 7,
    "max_backups": 30,
    "compress": true,
    "local_time": true,
    "rotate_daily": true
  }
}
